# Copy to .env and fill in (never commit .env)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# App URL (no trailing slash) — used for OAuth redirect after Google login
APP_URL=http://localhost:5500

# Google OAuth — also paste BOTH values in Supabase → Authentication → Providers → Google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Razorpay (public Key ID only — safe in browser)
RAZORPAY_KEY_ID=rzp_test_yourkeyhere

# GOOGLE_CLIENT_SECRET is stored in .env for your records only.
# It is NEVER written to env.config.js (browser). Supabase uses it server-side for Google login.
